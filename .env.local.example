# Firebase / GCP — single-line JSON of a service account key
GCP_SERVICE_ACCOUNT_JSON=
# Project ID the service account belongs to
GCP_PROJECT=
# Firebase service account ID for custom-token signing (must match Go: FIREBASE_SERVICE_ACCOUNT_ID)
FIREBASE_SERVICE_ACCOUNT_ID=
# LINE Login channel — must match the Go backend
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# Comma-separated UIDs (format "line:<lineUserId>") seeded as admin
ADMIN_UIDS=
# Public — read by the LIFF client
NEXT_PUBLIC_LIFF_ID=
NEXT_PUBLIC_API_URL=
# HMAC secret for bin QR tokens (must match Go: BIN_HMAC_SECRET, >=16 bytes)
BIN_HMAC_SECRET=
# off | log | enforce (must match Go: BIN_CONFIRM_MODE)
BIN_CONFIRM_MODE=
# GCS bucket for scan images
GCS_BUCKET=
# Roboflow detector
ROBOFLOW_API_KEY=
ROBOFLOW_HOST=
ROBOFLOW_MODEL=
ROBOFLOW_BOTTLE_CLASS=
BOTTLE_ACCEPT_THRESHOLD=
